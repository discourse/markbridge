#!/usr/bin/env bash
# Generate categorized release notes for the current version to stdout.
# Groups commits by prefix: FEATURE: -> Features, FIX: -> Bug Fixes,
# PERF: -> Performance.
# DEV:/DEPS: and other prefixes are dropped as not user-facing.
#
# Works with both merge styles:
# - Rebase merges land the individual commits, which are matched by
#   their subjects directly.
# - Squash merges carry the squashed commit subjects as "* <subject>"
#   body lines (repo setting squash_merge_commit_message=COMMIT_MESSAGES),
#   so a multi-commit PR keeps its categorized entries even when the
#   squash subject itself (usually the PR title) has a dropped prefix
#   like DEV:.
#
# Usage: bin/generate-release-notes [<previous-tag>]
# Requires: gh, git, ruby
set -euo pipefail

VERSION=$(ruby -r ./lib/markbridge/version -e 'puts Markbridge::VERSION')
TAG="v${VERSION}"

PREV_TAG="${1:-$(git tag --list 'v*' --sort=-v:refname | grep -v "^${TAG}$" | head -1)}"

if [ -z "${PREV_TAG}" ]; then
  echo "error: no previous v* tag found" >&2
  exit 1
fi

REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner)

features=""
fixes=""
perf=""

# Bucket one subject line, linked to the PR associated with `sha`
# (short SHA when there is none). Uncategorized subjects are ignored.
add_entry() {
  local sha=$1 subject=$2 bucket title pr ref entry

  case "${subject}" in
    FEATURE:*) bucket="features" ;;
    FIX:*)     bucket="fixes" ;;
    PERF:*)    bucket="perf" ;;
    *)         return 0 ;;
  esac

  title=${subject#*: }
  # Squash-commit subjects already carry a trailing " (#N)"; strip it so
  # the reference below doesn't double up.
  title=$(printf '%s' "${title}" | sed -E 's/ \(#[0-9]+\)$//')

  pr=$(gh api "repos/${REPO}/commits/${sha}/pulls" -q '.[0].number' 2>/dev/null || true)
  # gh can emit error JSON on stdout (e.g. for commits GitHub doesn't
  # know); only accept an all-digits PR number.
  case "${pr}" in
    "" | *[!0-9]*) ref=$(git rev-parse --short "${sha}") ;;
    *) ref="#${pr}" ;;
  esac
  entry="* ${title} (${ref})"$'\n'

  case "${bucket}" in
    features) features+="${entry}" ;;
    fixes)    fixes+="${entry}" ;;
    perf)     perf+="${entry}" ;;
  esac
}

for sha in $(git rev-list "${PREV_TAG}..HEAD"); do
  subject=$(git show -s --format='%s' "${sha}")

  case "${subject}" in
    FEATURE:* | FIX:* | PERF:*)
      add_entry "${sha}" "${subject}"
      ;;
    *)
      # Possibly a squash merge of a multi-commit PR: expand any
      # categorized subjects from the squash body's commit list.
      while IFS= read -r line; do
        add_entry "${sha}" "${line#\* }"
      done < <(git show -s --format='%b' "${sha}" | grep -E '^\* (FEATURE|FIX|PERF):' || true)
      ;;
  esac
done

{
  echo "## What's Changed"
  echo
  # UPGRADING.md sections are named after the release that ships them
  # (newest first); one matching this version means breaking changes.
  if grep -q "^## ${VERSION} " UPGRADING.md 2>/dev/null; then
    echo "> [!WARNING]"
    echo "> This release contains breaking changes — see [UPGRADING.md](https://github.com/${REPO}/blob/${TAG}/UPGRADING.md) before updating."
    echo
  fi
  if [ -n "${features}" ]; then
    echo "### ✨ Features"
    printf '%s' "${features}"
    echo
  fi
  if [ -n "${fixes}" ]; then
    echo "### 🐛 Bug Fixes"
    printf '%s' "${fixes}"
    echo
  fi
  if [ -n "${perf}" ]; then
    echo "### ⚡ Performance"
    printf '%s' "${perf}"
    echo
  fi
  echo "**Full Changelog**: https://github.com/${REPO}/compare/${PREV_TAG}...${TAG}"
}
